{
    "name": "kooditorm/hyperf-validation",
    "description": "Annotation validator for the Hyperf framework",
    "keywords": [
        "hyperf",
        "annotation",
        "validator"
    ],
    "homepage": "https://github.com/Kooditorm/hyperf-validation",
    "license": "MIT",
    "authors": [
        {
            "name": "oswin.hu",
            "email": "oswin.hu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "hyperf/validation": "^3.1.0",
        "hyperf/exception-handler": "^3.1.0",
        "hyperf/http-message": "^3.1.0"
    },
    "autoload": {
        "psr-4": {
            "Kooditorm\\Validation\\": "src/"
        }
    },
    "extra": {
        "hyperf": {
            "config": "Kooditorm\\Validation\\ConfigProvider"
        }
    }
}